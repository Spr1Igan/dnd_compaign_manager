#!/bin/sh
### BEGIN INIT INFO
# Provides:          php-cgi
# Required-Start:    $remote_fs $network
# Required-Stop:     $remote_fs $network
# Default-Start:     2 3 4 5
# Default-Stop:      0 1 6
# Short-Description: PHP CGI FastCGI socket for Nginx
### END INIT INFO

NAME="php-cgi"
PHP_CGI="/usr/bin/php-cgi"
SPAWN_FCGI="/usr/bin/spawn-fcgi"
SOCKET_DIR="/run/php"
SOCKET_PATH="$SOCKET_DIR/php-cgi.sock"
PID_FILE="/run/php/php-cgi.pid"
USER="www-data"
GROUP="www-data"

case "$1" in
    start)
        if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
            echo "$NAME is already running"
            exit 0
        fi

        mkdir -p "$SOCKET_DIR"
        chown "$USER:$GROUP" "$SOCKET_DIR"
        rm -f "$SOCKET_PATH"

        "$SPAWN_FCGI" \
            -s "$SOCKET_PATH" \
            -P "$PID_FILE" \
            -U "$USER" \
            -G "$GROUP" \
            -M 0660 \
            -u "$USER" \
            -g "$GROUP" \
            -- "$PHP_CGI"
        ;;

    stop)
        if [ -f "$PID_FILE" ]; then
            kill "$(cat "$PID_FILE")" 2>/dev/null || true
            rm -f "$PID_FILE"
        fi

        rm -f "$SOCKET_PATH"
        ;;

    restart|force-reload)
        "$0" stop
        sleep 1
        "$0" start
        ;;

    status)
        if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
            echo "$NAME is running"
            exit 0
        fi

        echo "$NAME is not running"
        exit 3
        ;;

    *)
        echo "Usage: $0 {start|stop|restart|force-reload|status}"
        exit 2
        ;;
esac

exit 0
